{
  "manifest_version": 3,
  "name": "Kookboek van Joost",
  "version": "1.0.0",
  "description": "Stuur een recept direct naar Het Kookboek van Joost",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Voeg recept toe aan kookboek"
  },
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "https://*.vercel.app/*",
    "<all_urls>"
  ]
}
